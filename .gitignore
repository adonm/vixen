# Rust / Cargo
/target
**/*.rs.bk
Cargo.lock.bak

# mdBook output
/book

# Workspace-local CARGO_HOME (docs/guidance/cargo-home.md). We pin
# `.cargo/config.toml` (project config); the cache subdirs are build state.
/.cargo/*
!/.cargo/config.toml

# cargo-fuzz build outputs. The harness source lives in fuzz/fuzz_targets/;
# corpora/artifacts are regenerated per run and are too large to ship.
/fuzz/target
/fuzz/corpus
/fuzz/artifacts
/fuzz/coverage

# flatpak-builder outputs (build-aux/). The manifest is shipped; these aren't.
/build-aux/_build
/build-aux/_repo
/build-aux/.flatpak-builder
/build-aux/.cargo
/build-aux/vixen.flatpak

# Reference browser checkouts (docs/REFERENCES.md) — never shipped
/reference-browsers

# Local profile data created while dogfooding
/profile/

# Editor / OS noise
.idea/
.vscode/
*.swp
.DS_Store

# Reftest diff output (docs/PLAN.md "Snapshot tests against Firefox reference")
/target-reftest-diff/

# Node tooling cache/install outputs. `package-lock.json` is tracked; modules are
# reproduced through mise-managed npm.
/node_modules/

# Workspace-local external checkouts and other reproducible scratch data
/.tmp/
